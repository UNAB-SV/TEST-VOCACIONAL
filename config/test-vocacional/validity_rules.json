{
  "validity_rules": {
    "requerimientos_base": {
      "mas_por_bloque": 1,
      "menos_por_bloque": 1,
      "permitir_duplicado_en_bloque": false
    },
    "metricas": [
      {
        "id": "omisiones",
        "formula": "count(bloque where mas is null or menos is null)",
        "umbral_invalido": 1
      },
      {
        "id": "colision_mas_menos",
        "formula": "count(bloque where actividad_mas == actividad_menos)",
        "umbral_invalido": 1
      },
      {
        "id": "indice_validez",
        "formula": "score('validez')"
      }
    ],
    "decision": [
      {
        "id": "no_valida_por_indice_menor_a_32",
        "si": "indice_validez < 32",
        "estado": "invalido"
      },
      {
        "id": "valida_por_indice_mayor_a_35",
        "si": "indice_validez > 35",
        "estado": "valido"
      },
      {
        "id": "dudosa_por_indice_entre_32_y_35",
        "si": "default",
        "estado": "dudoso"
      }
    ],
    "estado_reglas": "CONFIRMADO_EXCEL",
    "nota": "Regla tomada de la fórmula de la hoja \"Grafica de Resultados\" (celda D7): SI(B7<32,\"PRUEBA NO VÁLIDA\",SI(B7>35,\"PRUEBA VÁLIDA\",\"PRUEBA DUDOSA\")). Umbrales exactos: <32 inválido, 32..35 dudoso, >35 válido."
  }
}
